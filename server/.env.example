# 环境配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=welfare_recovery
DB_USER=root
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=7d

# 微信小程序配置
WX_APPID=your_appid
WX_SECRET=your_secret

# 加密配置
CRYPTO_KEY=your_crypto_key

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 第三方服务配置
VERIFY_API_URL=https://verify.example.com/api
VERIFY_API_KEY=your_verify_api_key