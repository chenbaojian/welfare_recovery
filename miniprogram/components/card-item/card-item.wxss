/* components/card-item/card-item.wxss */

.card-item {
  display: flex;
  align-items: center;
}

/* 网格模式 */
.grid-mode {
  flex-direction: column;
  padding: 15px 10px;
  background-color: #fff;
  border-radius: 8px;
  transition: all 0.3s;
}

.grid-mode:active {
  transform: scale(0.95);
  background-color: #f5f5f5;
}

.grid-mode .card-icon-emoji {
  font-size: 40px;
  margin-bottom: 8px;
}

.grid-mode .card-icon {
  width: 48px;
  height: 48px;
  margin-bottom: 8px;
}

.grid-mode .card-name {
  font-size: 12px;
  color: #333;
  text-align: center;
}

/* 列表模式 */
.list-mode {
  padding: 15px;
  background-color: #fff;
  border-radius: 8px;
}

.list-mode .card-icon-emoji {
  font-size: 32px;
  margin-right: 12px;
}

.list-mode .card-icon {
  width: 40px;
  height: 40px;
  margin-right: 12px;
}

.list-mode .card-info {
  flex: 1;
}

.list-mode .card-name {
  font-size: 14px;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 4px;
}

.list-mode .card-desc {
  font-size: 12px;
  color: #999;
  display: block;
}

.list-mode .card-discount {
  margin-right: 10px;
}

.list-mode .discount-text {
  font-size: 12px;
  color: #F5222D;
  font-weight: 500;
}