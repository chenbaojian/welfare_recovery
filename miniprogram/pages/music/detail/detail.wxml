<!-- pages/music/detail/detail.wxml -->
<view class="music-detail-container">
  <!-- 头部信息 -->
  <view class="header-section">
    <view class="header-icon">🎵</view>
    <text class="header-title">{{ typeName }}回收</text>
    <text class="header-discount">回收折扣: {{ discount * 10 }}折</text>
  </view>

  <!-- 输入卡号卡密 -->
  <view class="section">
    <view class="section-title">输入卡券信息</view>
    
    <view class="input-section">
      <view class="input-label">
        <text>卡号</text>
      </view>
      <input
        class="input-field"
        type="text"
        placeholder="请输入卡号"
        value="{{ cardNo }}"
        bindinput="onInputCardNo"
      />
    </view>

    <view class="input-section">
      <view class="input-label">
        <text>卡密</text>
      </view>
      <input
        class="input-field"
        type="text"
        password
        placeholder="请输入卡密"
        value="{{ cardPwd }}"
        bindinput="onInputCardPwd"
      />
    </view>

    <view class="input-section">
      <view class="input-label">
        <text>额度（元）</text>
      </view>
      <input
        class="input-field"
        type="digit"
        placeholder="请输入额度"
        value="{{ amount }}"
        bindinput="onInputAmount"
      />
    </view>
  </view>

  <!-- 回收金额 -->
  <view class="amount-section" wx:if="{{ amount }}">
    <view class="amount-row">
      <text class="amount-label">面值</text>
      <text class="amount-value">{{ amount }}元</text>
    </view>
    <view class="amount-row">
      <text class="amount-label">回收金额</text>
      <text class="amount-value highlight">{{ recycleAmount }}元</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section" wx:if="{{ amount }}">
    <van-button
      type="primary"
      block
      loading="{{ submitting }}"
      disabled="{{ submitting }}"
      bind:click="onSubmitOrder"
    >
      提交订单
    </van-button>
  </view>

  <!-- 温馨提示 -->
  <view class="notice-section">
    <view class="section-title">温馨提示</view>
    <view class="notice-content">
      <view class="notice-item">• 请确保卡券有效且未使用</view>
      <view class="notice-item">• 提交后无法撤销，请仔细核对卡号卡密</view>
      <view class="notice-item">• 回收金额将在1-3个工作日内到账</view>
    </view>
  </view>
</view>