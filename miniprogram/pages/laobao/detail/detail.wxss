/* pages/laobao/detail/detail.wxss */

.laobao-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 头部 */
.header-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30px 15px;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.header-icon {
  font-size: 40px;
  margin-bottom: 10px;
}

.header-title {
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 6px;
}

.header-discount {
  font-size: 12px;
  opacity: 0.9;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.form-item {
  margin-bottom: 20px;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.label-text {
  font-size: 14px;
  color: #333;
}

.label-required {
  color: #F5222D;
  margin-left: 4px;
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 15px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-input.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input-placeholder {
  color: #999;
}

.input-value {
  color: #333;
}

.form-unit {
  position: absolute;
  right: 15px;
  bottom: 14px;
  font-size: 14px;
  color: #999;
}

/* 金额区域 */
.amount-section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
}

.amount-label {
  font-size: 14px;
  color: #666;
}

.amount-value {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.amount-value.highlight {
  color: #F5222D;
  font-size: 20px;
}

/* 提交按钮 */
.submit-section {
  padding: 15px;
  margin-top: 15px;
}

/* 提示区域 */
.notice-section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.notice-title {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
}

.notice-content {
  padding-left: 0;
}

.notice-item {
  font-size: 12px;
  color: #999;
  line-height: 24px;
}

/* 平台选择弹窗 */
.platform-picker {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}

.picker-title {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

.picker-close {
  font-size: 14px;
  color: #1890FF;
}

.picker-list {
  flex: 1;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}

.picker-item:active {
  background-color: #f5f5f5;
}

.picker-item.active {
  color: #1890FF;
}
