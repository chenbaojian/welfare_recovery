<!-- pages/login/login.wxml -->
<view class="login-page">

  <!-- 顶部品牌区域 -->
  <view class="brand-area">
    <view class="brand-content">
      <view class="logo-wrap">
        <view class="logo-icon">🎁</view>
      </view>
      <text class="brand-name">福利回收</text>
      <text class="brand-slogan">闲置卡券 一键变现</text>
    </view>
    <view class="deco-circle deco-1"></view>
    <view class="deco-circle deco-2"></view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">

    <view class="welcome-section">
      <text class="welcome-title">欢迎登录</text>
      <text class="welcome-desc">登录后即可享受回收与购买服务</text>
    </view>

    <!-- 微信一键登录 -->
    <button
      class="login-btn wx-btn"
      bindtap="onWxLogin"
    >
      <van-icon name="wechat" size="20" color="#fff" custom-style="margin-right:8px" />
      <text wx:if="{{ !loading }}">微信一键登录</text>
      <van-loading wx:if="{{ loading }}" size="20px" color="#fff" />
    </button>

    <!-- 手机号登录 -->
    <button
      class="login-btn phone-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      bindtap="onPhoneBtnTap"
    >
      <van-icon name="phone" size="20" color="#fff" custom-style="margin-right:8px" />
      <text wx:if="{{ !loading }}">手机号登录</text>
      <van-loading wx:if="{{ loading }}" size="20px" color="#fff" />
    </button>

    <!-- 协议 -->
    <view class="agreement">
      <view class="agreement-check" bindtap="onToggleAgree">
        <view class="check-box {{ agreed ? 'checked' : '' }}">
          <view wx:if="{{ agreed }}" class="check-mark">✓</view>
        </view>
      </view>
      <view class="agreement-text-wrap" bindtap="onToggleAgree">
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" catchtap="onViewUserProtocol">《用户协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" catchtap="onViewPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>

  </view>

  <!-- 游客入口 -->
  <view class="guest-entry" bindtap="onBackToHome">
    <text class="guest-text">暂不登录，先逛逛</text>
  </view>

</view>
