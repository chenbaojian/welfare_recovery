/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f7fa;
}

/* ========== 品牌区域 ========== */
.brand-area {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #1890FF 0%, #36a3ff 50%, #69c0ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.brand-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 72rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.deco-1 {
  width: 300rpx;
  height: 300rpx;
  top: -80rpx;
  right: -60rpx;
}

.deco-2 {
  width: 200rpx;
  height: 200rpx;
  bottom: -40rpx;
  left: -40rpx;
}

/* ========== 登录卡片 ========== */
.login-card {
  position: relative;
  z-index: 3;
  margin: -60rpx 40rpx 0;
  padding: 60rpx 48rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.welcome-section {
  margin-bottom: 50rpx;
}

.welcome-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.welcome-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* ========== 登录按钮（统一尺寸，彻底重置 button 默认样式） ========== */
.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-sizing: border-box;
  /* 重置微信 button 默认样式 */
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
  background: transparent;
  overflow: visible;
}

.login-btn::after {
  border: none;
}

/* 微信登录 - 绿色 */
.wx-btn {
  background: linear-gradient(135deg, #07C160 0%, #2dc770 100%);
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 24rpx;
}

.wx-btn:active {
  opacity: 0.85;
}

/* 手机号登录 - 蓝色 */
.phone-btn {
  background: linear-gradient(135deg, #1890FF 0%, #36a3ff 100%);
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.phone-btn:active {
  opacity: 0.85;
}

/* ========== 协议 ========== */
.agreement {
  display: flex;
  align-items: flex-start;
  margin-top: 36rpx;
}

.agreement-check {
  flex-shrink: 0;
  margin-right: 10rpx;
  padding-top: 2rpx;
}

.check-box {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  transition: all 0.2s;
}

.check-box.checked {
  background: #1890FF;
  border-color: #1890FF;
}

.check-mark {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
  font-weight: 700;
}

.agreement-text-wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.agreement-text {
  font-size: 22rpx;
  color: #999;
  line-height: 36rpx;
}

.agreement-link {
  font-size: 22rpx;
  color: #1890FF;
  line-height: 36rpx;
}

/* ========== 游客入口 ========== */
.guest-entry {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 80rpx;
}

.guest-text {
  font-size: 28rpx;
  color: #bbb;
}
