/* pages/meituan/detail/detail.wxss */

.meituan-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 头部 */
.header-section {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 30px 15px;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.header-icon {
  font-size: 40px;
  margin-bottom: 10px;
}

.header-title {
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 6px;
}

.header-discount {
  font-size: 12px;
  opacity: 0.9;
}

/* 通用section */
.section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 15px;
}

/* 输入区域 */
.input-section {
  margin-bottom: 20px;
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.input-label text {
  font-size: 14px;
  color: #333;
}

.input-field {
  width: 100%;
  height: 44px;
  padding: 0 15px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  box-sizing: border-box;
}

/* 面值选择 */
.face-value-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.face-value-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 15px 0;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  transition: all 0.3s;
}

.face-value-item.active {
  border-color: #FFD700;
  background-color: rgba(255, 215, 0, 0.1);
}

.face-value-text {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.face-value-amount {
  font-size: 10px;
  color: #F5222D;
  margin-top: 4px;
}

/* 金额区域 */
.amount-section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
}

.amount-label {
  font-size: 14px;
  color: #666;
}

.amount-value {
  font-size: 16px;
  color: #333;
  font-weight: 500;
}

.amount-value.highlight {
  color: #F5222D;
  font-size: 20px;
}

/* 提交按钮 */
.submit-section {
  padding: 15px;
  margin-top: 15px;
}

/* 提示区域 */
.notice-section {
  background-color: #fff;
  padding: 15px;
  margin-top: 15px;
}

.notice-content {
  padding-left: 0;
}

.notice-item {
  font-size: 12px;
  color: #999;
  line-height: 24px;
}