<!-- pages/meituan/detail/detail.wxml -->
<view class="meituan-detail-container">
  <!-- 头部信息 -->
  <view class="header-section">
    <view class="header-icon">🎁</view>
    <text class="header-title">美团企业积分回收</text>
    <text class="header-discount">回收折扣: {{ discount * 10 }}折</text>
  </view>

  <!-- 输入账号信息 -->
  <view class="section">
    <view class="section-title">输入账号信息</view>
    
    <view class="input-section">
      <view class="input-label">
        <text>手机号</text>
      </view>
      <input
        class="input-field"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        value="{{ phone }}"
        bindinput="onInputPhone"
      />
    </view>

    <view class="input-section">
      <view class="input-label">
        <text>登录密码</text>
      </view>
      <input
        class="input-field"
        type="text"
        password
        placeholder="请输入登录密码"
        value="{{ password }}"
        bindinput="onInputPassword"
      />
    </view>
  </view>

  <!-- 选择面值 -->
  <view class="section">
    <view class="section-title">选择面值</view>
    <view class="face-value-list">
      <view
        class="face-value-item {{ selectedFaceValue === item ? 'active' : '' }}"
        wx:for="{{ faceValues }}"
        wx:key="*this"
        data-value="{{ item }}"
        bindtap="onSelectFaceValue"
      >
        <text class="face-value-text">{{ item }}元</text>
        <text class="face-value-amount" wx:if="{{ selectedFaceValue === item }}">回收{{ item * discount }}元</text>
      </view>
    </view>
  </view>

  <!-- 回收金额 -->
  <view class="amount-section" wx:if="{{ selectedFaceValue }}">
    <view class="amount-row">
      <text class="amount-label">面值</text>
      <text class="amount-value">{{ selectedFaceValue }}元</text>
    </view>
    <view class="amount-row">
      <text class="amount-label">回收金额</text>
      <text class="amount-value highlight">{{ recycleAmount }}元</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section" wx:if="{{ selectedFaceValue }}">
    <van-button
      type="primary"
      block
      loading="{{ submitting }}"
      disabled="{{ submitting }}"
      bind:click="onSubmitOrder"
    >
      提交订单
    </van-button>
  </view>

  <!-- 温馨提示 -->
  <view class="notice-section">
    <view class="section-title">温馨提示</view>
    <view class="notice-content">
      <view class="notice-item">• 请确保账号信息正确且积分有效</view>
      <view class="notice-item">• 提交后无法撤销，请仔细核对信息</view>
      <view class="notice-item">• 回收金额将在1-3个工作日内到账</view>
    </view>
  </view>
</view>