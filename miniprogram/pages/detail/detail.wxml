<!-- pages/detail/detail.wxml -->
<wxs src="./utils.wxs" module="utils" />

<view class="detail-container">
  <!-- 加载中 -->
  <view class="loading-section" wx:if="{{ loading }}">
    <van-loading size="24px" vertical>加载中...</van-loading>
  </view>

  <!-- 主内容 -->
  <view class="main-content" wx:else>
    <!-- 卡券信息 -->
    <view class="card-info-section">
      <view class="card-header">
        <view class="card-icon-emoji">{{ cardType.icon }}</view>
        <view class="card-text">
          <text class="card-name">{{ cardType.name }}</text>
          <text class="card-desc">{{ cardType.description }}</text>
        </view>
      </view>

      <!-- 回收折扣 -->
      <view class="discount-info">
        <text class="discount-label">回收折扣</text>
        <text class="discount-value">{{ utils.formatDiscount(cardType.discount) }}折</text>
      </view>
    </view>

    <!-- 提示信息 -->
    <van-notice-bar
      wx:if="{{ cardType.notice }}"
      left-icon="info-o"
      text="{{ cardType.notice }}"
      bindtap="onViewNotice"
    />

    <!-- 选择面值 -->
    <view class="face-value-section">
      <view class="section-title">选择面值</view>
      <view class="value-grid">
        <view
          class="value-item {{ selectedValue === item ? 'active' : '' }}"
          wx:for="{{ faceValues }}"
          wx:key="*this"
          data-value="{{ item }}"
          bindtap="onSelectValue"
        >
          <text class="value-text">{{ item }}元</text>
        </view>
      </view>
    </view>

    <!-- 回收金额 -->
    <view class="amount-section" wx:if="{{ selectedValue }}">
      <view class="amount-row">
        <text class="amount-label">面值金额</text>
        <text class="amount-value">¥{{ selectedValue }}</text>
      </view>
      <view class="amount-row highlight">
        <text class="amount-label">回收金额</text>
        <text class="amount-value">¥{{ recycleAmount }}</text>
      </view>
    </view>

    <!-- 输入卡号卡密 -->
    <view class="form-section">
      <view class="section-title">卡券信息</view>
      <van-cell-group inset>
        <!-- 卡号 -->
        <van-field
          value="{{ form.cardNo }}"
          label="卡号"
          placeholder="请输入卡号"
          required
          clearable
          maxlength="{{ cardType.cardNoMaxLength || 30 }}"
          bind:change="onCardNoInput"
          error-message="{{ errors.cardNo }}"
        />

        <!-- 卡密 -->
        <van-field
          value="{{ form.cardPwd }}"
          label="卡密"
          placeholder="请输入卡密"
          required
          clearable
          password
          maxlength="{{ cardType.cardPwdMaxLength || 20 }}"
          bind:change="onCardPwdInput"
          error-message="{{ errors.cardPwd }}"
        />
      </van-cell-group>
    </view>

    <!-- 注意事项 -->
    <view class="notice-section">
      <view class="notice-title">注意事项</view>
      <view class="notice-item">• 请确保卡券有效且未使用</view>
      <view class="notice-item">• 提交后无法撤销，请核对信息</view>
      <view class="notice-item">• 回收金额将存入账户余额</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <view
        class="submit-btn {{ submitting || !selectedValue ? 'disabled' : '' }}"
        bindtap="onSubmit"
      >
        <text wx:if="{{ !submitting }}">提交订单</text>
        <van-loading wx:if="{{ submitting }}" size="20px" color="#fff" />
      </view>
    </view>
  </view>
</view>

<van-dialog id="van-dialog" />