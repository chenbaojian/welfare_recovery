<!-- pages/detail/detail.wxml -->
<wxs module="utils">
// WXS 不支持 toFixed，用数学运算替代
function pad2(n) {
  n = Math.floor(n);
  if (n < 10) return '0' + n;
  return '' + n;
}

module.exports = {
  formatMoney: function(val) {
    if (!val && val !== 0) return '0.00';
    var sign = val < 0 ? '-' : '';
    var abs = Math.abs(val);
    var intPart = Math.floor(abs);
    var decPart = Math.floor((abs - intPart) * 100 + 0.5);
    if (decPart >= 100) {
      intPart += 1;
      decPart = 0;
    }
    return sign + intPart + '.' + pad2(decPart);
  },
  formatDiscount: function(rate) {
    if (!rate && rate !== 0) return '';
    var d = Math.round(rate * 100) / 10;
    if (d === Math.floor(d)) return '' + d;
    return '' + d;
  }
};
</wxs>

<view class="detail-container">
  <!-- 加载中 -->
  <view class="loading-section" wx:if="{{ loading }}">
    <van-loading size="24px" vertical>加载中...</van-loading>
  </view>

  <!-- 主内容 -->
  <view class="main-content" wx:else>
    <!-- 卡券信息头部 -->
    <view class="card-info-section">
      <view class="card-header">
        <view class="card-icon-emoji">{{ cardType.icon || '🎫' }}</view>
        <view class="card-text">
          <text class="card-name">{{ cardProductName || cardType.name }}</text>
          <text class="card-desc" wx:if="{{ cardType.description }}">{{ cardType.description }}</text>
        </view>
      </view>
    </view>

    <!-- 提示信息 -->
    <van-notice-bar
      wx:if="{{ cardType.notice }}"
      left-icon="info-o"
      text="{{ cardType.notice }}"
      bindtap="onViewNotice"
    />

    <!-- 选择面值 -->
    <view class="face-value-section">
      <view class="section-title">选择面值</view>
      <view class="value-grid">
        <view
          class="value-item {{ selectedFaceValue && selectedFaceValue.id === item.id ? 'active' : '' }}"
          wx:for="{{ faceValues }}"
          wx:key="id"
          data-index="{{ index }}"
          bindtap="onSelectValue"
        >
          <text class="value-amount">{{ item.faceValue }}元</text>
          <text class="value-discount">{{ item.discountText }}</text>
        </view>
      </view>
    </view>

    <!-- 回收金额 -->
    <view class="amount-section" wx:if="{{ selectedFaceValue }}">
      <view class="amount-row">
        <text class="amount-label">面值金额</text>
        <text class="amount-value">¥{{ selectedFaceValue.faceValue }}</text>
      </view>
      <view class="amount-row">
        <text class="amount-label">收卡折扣</text>
        <text class="amount-value discount-value">{{ selectedFaceValue.discountText }}</text>
      </view>
      <view class="amount-row highlight">
        <text class="amount-label">回收金额</text>
        <text class="amount-value recycle-value">¥{{ recycleAmount }}</text>
      </view>
    </view>

    <!-- 输入卡号卡密 -->
    <view class="form-section">
      <view class="section-title">卡券信息</view>
      <van-cell-group inset>
        <!-- 卡号 -->
        <van-field
          value="{{ form.cardNo }}"
          label="卡号"
          placeholder="请输入卡号"
          required
          clearable
          maxlength="30"
          bind:input="onCardNoInput"
          error-message="{{ errors.cardNo }}"
        />

        <!-- 卡密 -->
        <van-field
          value="{{ form.cardPwd }}"
          label="卡密"
          placeholder="请输入卡密"
          required
          clearable
          password
          maxlength="30"
          bind:input="onCardPwdInput"
          error-message="{{ errors.cardPwd }}"
        />
      </van-cell-group>
    </view>

    <!-- 注意事项 -->
    <view class="notice-section">
      <view class="notice-title">注意事项</view>
      <view class="notice-item">• 请确保卡券有效且未使用</view>
      <view class="notice-item">• 提交后无法撤销，请核对信息</view>
      <view class="notice-item">• 回收金额将存入账户余额</view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <view
        class="submit-btn {{ submitting || !selectedFaceValue ? 'disabled' : '' }}"
        bindtap="onSubmit"
      >
        <text wx:if="{{ !submitting }}">提交订单</text>
        <van-loading wx:if="{{ submitting }}" size="20px" color="#fff" />
      </view>
    </view>
  </view>
</view>

<van-dialog id="van-dialog" />
