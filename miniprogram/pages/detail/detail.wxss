/* pages/detail/detail.wxss */

.detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 加载中 */
.loading-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100px 0;
}

/* 卡券信息 */
.card-info-section {
  background-color: #fff;
  padding: 20px 15px;
  margin-bottom: 10px;
}

.card-header {
  display: flex;
  align-items: center;
}

.card-icon-emoji {
  font-size: 40px;
  margin-right: 15px;
}

.card-text {
  flex: 1;
}

.card-name {
  font-size: 18px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 5px;
}

.card-desc {
  font-size: 13px;
  color: #999;
  display: block;
}

/* 选择面值 */
.face-value-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.section-title {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 15px;
}

.value-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.value-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10px 4px;
  background-color: #f5f5f5;
  border-radius: 8px;
  border: 1px solid transparent;
  transition: all 0.3s;
}

.value-item.active {
  background-color: rgba(24, 144, 255, 0.08);
  border-color: #1890FF;
}

.value-amount {
  font-size: 14px;
  color: #333;
  font-weight: 500;
  margin-bottom: 2px;
}

.value-discount {
  font-size: 11px;
  color: #F5222D;
}

.value-item.active .value-amount {
  color: #1890FF;
}

.value-item.active .value-discount {
  color: #1890FF;
  font-weight: 500;
}

/* 回收金额 */
.amount-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

.amount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 0;
}

.amount-row.highlight {
  border-top: 1px solid #f0f0f0;
  padding-top: 12px;
  margin-top: 4px;
}

.amount-label {
  font-size: 14px;
  color: #666;
}

.amount-value {
  font-size: 15px;
  color: #333;
}

.discount-value {
  color: #F5222D;
  font-size: 14px;
}

.amount-row.highlight .recycle-value {
  font-size: 20px;
  font-weight: bold;
  color: #F5222D;
}

/* 表单区域 */
.form-section {
  background-color: #fff;
  padding: 15px;
  margin-bottom: 10px;
}

/* 注意事项 */
.notice-section {
  background-color: #fff;
  padding: 15px;
  margin: 0 15px 15px;
  border-radius: 8px;
}

.notice-title {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
}

.notice-item {
  font-size: 12px;
  color: #999;
  line-height: 2;
}

/* 提交按钮 */
.submit-section {
  padding: 20px 15px;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background-color: #1890FF;
  color: #fff;
  font-size: 16px;
  border-radius: 24px;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn.disabled {
  opacity: 0.5;
}
