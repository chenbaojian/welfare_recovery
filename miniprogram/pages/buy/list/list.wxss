/* pages/buy/list/list.wxss - 买家卡券列表页 */

.buy-list-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 页面标题 */
.page-header {
  display: flex;
  align-items: center;
  padding: 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.header-icon {
  font-size: 28px;
  margin-right: 10px;
}

.header-title {
  font-size: 16px;
  font-weight: 500;
  color: #333;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  padding: 10px 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.sort-item {
  flex: 1;
  text-align: center;
  font-size: 13px;
  color: #666;
  padding: 6px 0;
  border-radius: 4px;
}

.sort-item.active {
  color: #1890FF;
  font-weight: 500;
  background-color: rgba(24, 144, 255, 0.1);
}

/* 加载中 */
.loading-section {
  display: flex;
  justify-content: center;
  padding: 40px 0;
}

/* 卡券列表 */
.card-list {
  padding: 10px 15px;
}

.card-card {
  background-color: #fff;
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 10px;
  position: relative;
  overflow: hidden;
}

.card-card:active {
  background-color: #fafafa;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-type-info {
  flex: 1;
}

.card-type-name {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.card-face-value {
  font-size: 12px;
  color: #999;
  display: block;
}

.card-price-box {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.card-price {
  font-size: 18px;
  font-weight: 600;
  color: #F5222D;
  display: block;
}

.card-original {
  font-size: 12px;
  color: #999;
  text-decoration: line-through;
  display: block;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid #f0f0f0;
}

.card-seller {
  font-size: 12px;
  color: #666;
}

.card-time {
  font-size: 12px;
  color: #999;
}

.card-discount-tag {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #F5222D;
  color: #fff;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 0 8px 0 8px;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 10px;
}

.empty-text {
  font-size: 14px;
  color: #999;
  margin-bottom: 5px;
}

.empty-sub {
  font-size: 12px;
  color: #ccc;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 15px 0;
}

.no-more {
  text-align: center;
  padding: 15px 0;
  font-size: 12px;
  color: #999;
}