/* pages/card/list/list.wxss */

.card-list-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30px;
}

/* 加载中 */
.loading-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100px 0;
}

/* 提示信息 */
.tip-section {
  margin-bottom: 15px;
}

/* 主内容 */
.main-content {
  padding: 15px;
}

/* 卡产品列表 */
.product-list {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 16px 15px;
  border-bottom: 1px solid #f0f0f0;
  transition: background-color 0.2s;
}

.product-item:last-child {
  border-bottom: none;
}

.product-item:active {
  background-color: #f5f5f5;
}

/* 卡产品图标 */
.product-icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
  overflow: hidden;
}

/* 卡产品图片图标 */
.product-icon-img {
  width: 48px;
  height: 48px;
  border-radius: 12px;
}

/* 卡产品默认图标（彩色圆形+首字） */
.product-icon-default {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  line-height: 1;
}

/* 卡产品信息 */
.product-info {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-tags {
  display: flex;
  align-items: center;
  gap: 6px;
}

.hot-tag {
  font-size: 10px;
  color: #F5222D;
  background-color: rgba(245, 34, 45, 0.08);
  padding: 1px 6px;
  border-radius: 2px;
}

/* 箭头 */
.product-arrow {
  padding-left: 10px;
  flex-shrink: 0;
}

/* 空状态 */
.empty-section {
  padding-top: 80px;
}

.empty-tip {
  text-align: center;
  margin-top: -10px;
}

.empty-tip text {
  font-size: 13px;
  color: #999;
}
